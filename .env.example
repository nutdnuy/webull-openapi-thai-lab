WEBULL_ENV=uat
WEBULL_REGION=us
WEBULL_APP_KEY=replace_with_your_app_key
WEBULL_APP_SECRET=replace_with_your_app_secret
WEBULL_ACCOUNT_ID=replace_after_running_account_list
WEBULL_TOKEN_DIR=.webull-token
WEBULL_ALLOW_LIVE_ORDERS=NO
WEBULL_TUTORIAL_LIVE=0
WEBULL_TUTORIAL_OUTPUT_DIR=outputs/webull-th-beginner
SEC_CONTACT_EMAIL=your_monitored_email@example.com
SEC_CACHE_DIR=data/private/sec-cache
SEC_TIMEOUT_SECONDS=20
SEC_MAX_ATTEMPTS=3
SEC_WEBULL_TUTORIAL_LIVE=0
SEC_WEBULL_TUTORIAL_OUTPUT_DIR=outputs/sec-webull-financials
